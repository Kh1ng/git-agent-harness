# Rust
/target
**/*.rs.bk
# apps/desktop is a separate crate (its own Cargo.toml, not a workspace
# member of the root one) -- the root-anchored /target rule above doesn't
# reach its build directory.
/apps/desktop/target
# Generated by tauri-build's build.rs (added this pass) -- pure build
# output, regenerated on every build.
/apps/desktop/gen

# TypeScript/JavaScript
node_modules/
/pnpm-lock.yaml
**/.vite/
**/.vitest/
coverage/
**/.nyc_output/
**/.cache/
**/.next/
**/.pytest_cache/
**/__pycache__/

# Build outputs
/dist
/dist-electron
/dist-electron-packages
/**.output
**/dist/

# TypeScript cache
/.cache
**/*.tsbuildinfo

# Regenerated by `npm run generate:codex-schemas` (issue #527) from
# whichever `codex` binary is installed -- not committed, since it's
# reproducible from that binary and pins to its exact version.
/packages/contracts/src/generated/codex/

# IDE
.idea
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# Package manager locks (except pnpm-lock.yaml)
# Note: package-lock.json is tracked for npm workspaces
/yarn.lock

# Electron builder
/electron-builder.env

# Web app build outputs
/apps/web/dist/
/apps/web/build/
/apps/web/.next/

# Server and desktop temp files
*.tmp
*.temp

# Playwright (added this pass, apps/web)
/apps/web/test-results/
/apps/web/playwright-report/

# Existing ignores
OPENHANDS_TASK.md
TODO.md
docs/MANAGER_MEMORY.md
artifacts/
dist/
deploy/
.worktrees/
