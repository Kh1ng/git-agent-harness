{
  "name": "git-agent-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.js dev",
    "dev:server": "node scripts/dev-runner.js dev:server",
    "dev:web": "node scripts/dev-runner.js dev:web",
    "dev:desktop": "node scripts/dev-runner.js dev:desktop",
    "start": "node apps/server/dist/bin.js",
    "start:desktop": "node apps/desktop/scripts/start-electron.js",
    "build": "pnpm run build:rust && pnpm run build:server && pnpm run build:web && pnpm run build:desktop",
    "build:rust": "cd rust-backend && cargo build --release",
    "build:server": "cd apps/server && pnpm run build",
    "build:web": "cd apps/web && pnpm run build",
    "build:desktop": "cd apps/desktop && pnpm run build",
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:web && pnpm run typecheck:desktop",
    "lint": "pnpm run lint:server && pnpm run lint:web && pnpm run lint:desktop",
    "clean": "rm -rf apps/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}