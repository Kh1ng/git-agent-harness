{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@git-agent-harness/contracts": ["packages/contracts/src/index.ts"],
      "@git-agent-harness/shared": ["packages/shared/src/index.ts"]
    }
  },
  "references": [
    { "path": "./apps/server" },
    { "path": "./apps/web" },
    { "path": "./apps/desktop" },
    { "path": "./packages/contracts" },
    { "path": "./packages/shared" }
  ]
}