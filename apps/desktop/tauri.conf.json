{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Agent Harness Desktop",
  "version": "0.1.0",
  "identifier": "com.kh1ng.git-agent-harness-desktop",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main",
          "description": "Main application capabilities",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-execute",
            "shell:allow-open",
            "shell:allow-sidecar",
            "fs:allow-read-file",
            "fs:allow-read-dir",
            "fs:allow-exists",
            "path:allow-all",
            "window:allow-all",
            "dialog:allow-open",
            "dialog:allow-save",
            "clipboard:allow-write-text",
            "clipboard:allow-read-text",
            "notification:allow-all"
          ]
        }
      ]
    },
    "windows": [
      {
        "title": "Git Agent Harness Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ]
  },
  "build": {
    "frontendDist": "../web/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000"
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}