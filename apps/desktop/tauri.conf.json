{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Agent Harness Desktop",
  "version": "0.1.0",
  "identifier": "com.kh1ng.git-agent-harness-desktop",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main",
          "description": "Main application capabilities",
          "windows": ["main"],
          "permissions": [
            "core:default"
          ]
        }
      ]
    },
    "windows": [
      {
        "title": "Git Agent Harness Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ]
  },
  "build": {
    "frontendDist": "../web/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000"
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}