{
  "name": "gah-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "ensure:electron": "node scripts/ensure-electron-runtime.js",
    "start": "node scripts/start-electron.js",
    "typecheck": "tsc --noEmit",
    "build": "vite build && node scripts/build-desktop-artifact.js",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "electron": "^29.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "@git-agent-harness/client-runtime": "workspace:*",
    "@git-agent-harness/contracts": "workspace:*",
    "@git-agent-harness/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "cross-env": "^10.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^3.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "productName": "Git Agent Harness Desktop",
  "engines": {
    "node": ">=18.0.0"
  }
}